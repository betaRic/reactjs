# Recommended multi-Page Meta connection. These stay server-only.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_TOKEN_ENCRYPTION_KEY=

# Added by a Vercel Marketplace Postgres integration.
DATABASE_URL=

# Optional legacy single-Page fallback.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Legacy fallback key used to authorize publishing from the browser UI.
# Generate at least 32 random characters and enter the same value in Settings.
FACEBOOK_PUBLISH_KEY=

# Optional. Keep aligned with the Meta app's supported Graph API version.
FACEBOOK_GRAPH_API_VERSION=v25.0

# Added automatically when a public Vercel Blob store is connected to the project.
# Required for direct browser video uploads; never expose this value to the client.
BLOB_READ_WRITE_TOKEN=

# Optional canonical URL used for social metadata outside Vercel.
NEXT_PUBLIC_SITE_URL=https://socialmedia-dilg12.vercel.app
