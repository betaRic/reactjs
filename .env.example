# Recommended multi-Page Meta connection. These stay server-only.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_TOKEN_ENCRYPTION_KEY=

# Added by a Vercel Marketplace Postgres integration. The app accepts either.
DATABASE_URL=
POSTGRES_URL=

# Optional. Keep aligned with the Meta app's supported Graph API version.
FACEBOOK_GRAPH_API_VERSION=v25.0

# Current Vercel Blob connections use OIDC and provide BLOB_STORE_ID automatically.
# Older token-based stores provide BLOB_READ_WRITE_TOKEN. The app accepts either.
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# Optional canonical URL used for social metadata outside Vercel.
NEXT_PUBLIC_SITE_URL=https://socialmedia-dilg12.vercel.app
