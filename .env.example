# Target Facebook Page and server-only Page access token.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# A separate strong secret used to authorize publishing from the browser UI.
# Generate at least 32 random characters and enter the same value in Settings.
FACEBOOK_PUBLISH_KEY=

# Optional. Keep aligned with the Meta app's supported Graph API version.
FACEBOOK_GRAPH_API_VERSION=v25.0

# Optional canonical URL used for social metadata outside Vercel.
NEXT_PUBLIC_SITE_URL=https://socialmedia-dilg12.vercel.app
